# OpenAI API Key
# OPENAI_API_KEY=sk-YourActualOpenAIKeyHere

# Google Gemini API Key
# GEMINI_API_KEY=YourGoogleGeminiAPIKeyHere

# Master Key for your OTHER LiteLLM proxy instance
# LITELLM_API_KEY=sk-master-key-for-other-proxy

# LiteLLM Proxy Security
LITELLM_MASTER_KEY="sk-123456789-demo-key"
LITELLM_SALT_KEY="generate-a-random-string-for-this" # IMPORTANT: CANNOT BE CHANGED LATER

# Database Credentials (for the new postgres container)
POSTGRES_USER=litellm
POSTGRES_PASSWORD=a-very-strong-password
POSTGRES_DB=litellm_db
