# DDEV
.ddev/*
!.ddev/config.yaml
!.ddev/config.*.yaml
!.ddev/additional_hostnames
!.ddev/additional_fqdns
!.ddev/commands
!.ddev/homeadditions
!.ddev/patches

# DDEV generated files
.ddev/.gitignore
.ddev/import.yaml
.ddev/sequelpro.spf
.ddev/db_snapshots/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Editor directories and files
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.bak
*~

# Logs
*.log
logs/

# Dependency directories
node_modules/

# Composer / vendor
vendor/
composer.lock

# Drupal core & contributed code (managed by Composer)
web/core/
web/modules/contrib/
web/themes/contrib/
web/profiles/contrib/
web/libraries/

# Drupal scaffold files (auto-generated by drupal/core-composer-scaffold)
web/autoload.php
web/index.php
web/update.php
web/install.php
web/robots.txt
web/.htaccess
web/web.config
web/.csslintrc
web/.eslintignore
web/.eslintrc.json
web/.gitattributes
web/example.gitignore

# Drupal sites directory (keep the default folder, ignore generated/sensitive files)
web/sites/*/files/
web/sites/*/private/
web/sites/*/tmp/
web/sites/*/translations/
web/sites/*/settings.php
web/sites/*/settings.local.php
web/sites/*/services.yml

# Keep default.* files (used as templates)
!web/sites/default/default.settings.php
!web/sites/default/default.services.yml

# Drupal file sync / config export directory contents (optional — remove if you commit config)
# config/sync/

# Drush
drush/sites/

# Environment files
.env
.env.local
.env.*.local

# Build output
dist/
build/